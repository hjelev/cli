---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface BreadcrumbSegment {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	command: string;
	mode?: string;
	status?: string;
	editHref?: string;
	backHref?: string;
	noindex?: boolean;
	breadcrumb?: BreadcrumbSegment[];
}

const {
	title,
	command,
	mode = 'NORMAL',
	status,
	editHref,
	backHref,
	noindex = false,
	breadcrumb = [],
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="theme-color" content="#0f1013" media="(prefers-color-scheme: dark)" />
		<meta name="theme-color" content="#e4e9df" media="(prefers-color-scheme: light)" />
		{noindex && <meta name="robots" content="noindex, follow" />}
		<title>{title}</title>
		<script defer src="https://m.masoko.net/core-util" data-website-id="b005feb8-941a-4967-b499-0a0b5f2eff9e"></script>
	</head>
	<body>
		<div class="term">
			<div class="term-bar">
				<span class="term-logo"><Logo /></span>
				<p class="term-title"><span class="user">visitor@cli.masoko.net</span>:~$ {command}</p>
				{backHref && <a class="back" href={backHref}>&larr; cd ..</a>}
			</div>
			<div class="term-body">
				<slot />
			</div>
			<footer class="statusline">
				<span class="mode">{mode}</span>
				<span class="seg path">
					~/{breadcrumb.length > 0 ? <a href="/">cli.masoko.net</a> : 'cli.masoko.net'}
					{breadcrumb.map((segment, i) => (
						<>
							<span class="sep">/</span>
							{i < breadcrumb.length - 1 && segment.href ? (
								<a href={segment.href}>{segment.label}</a>
							) : (
								segment.label
							)}
						</>
					))}
				</span>
				{status && <span class="seg">{status}</span>}
				<span class="seg right">
					{editHref && (
						<>
							<a href={editHref}>edit</a>
							<span class="sep">·</span>
						</>
					)}
					<a href="/submit">submit</a>
					<span class="sep">·</span>
					<a class="icon-link" href="https://github.com/hjelev/cli" target="_blank" rel="noopener" aria-label="GitHub repository">
						<svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
							<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0 0 16 8c0-4.42-3.58-8-8-8Z"></path>
						</svg>
					</a>
				</span>
			</footer>
		</div>
	</body>
</html>
