---
import '../styles/global.css';

interface Props {
	title: string;
	command: string;
	mode?: string;
	status?: string;
}

const { title, command, mode = 'NORMAL', status } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<div class="term">
			<div class="term-bar">
				<div class="term-dots"><span></span><span></span><span></span></div>
				<p class="term-title"><span class="user">visitor@cli-tools</span>:~$ {command}</p>
			</div>
			<div class="term-body">
				<slot />
			</div>
			<footer class="statusline">
				<span class="mode">{mode}</span>
				<span class="seg path">~/cli-tools</span>
				{status && <span class="seg">{status}</span>}
				<span class="seg right">
					<a href="/submit">submit</a>
					<span class="sep">·</span>
					<a href="https://github.com/hjelev/cli" target="_blank" rel="noopener">github</a>
				</span>
			</footer>
		</div>
	</body>
</html>
