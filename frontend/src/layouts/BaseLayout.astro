---
import '../styles/global.css';
import Logo from '../components/Logo.astro';

interface BreadcrumbSegment {
	label: string;
	href?: string;
}

interface Props {
	title: string;
	command: string;
	mode?: string;
	status?: string;
	editHref?: string;
	backHref?: string;
	noindex?: boolean;
	breadcrumb?: BreadcrumbSegment[];
}

const {
	title,
	command,
	mode = 'NORMAL',
	status,
	editHref,
	backHref,
	noindex = false,
	breadcrumb = [],
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		{noindex && <meta name="robots" content="noindex, follow" />}
		<title>{title}</title>
		<script defer src="https://m.masoko.net/core-util" data-website-id="b005feb8-941a-4967-b499-0a0b5f2eff9e"></script>
	</head>
	<body>
		<div class="term">
			<div class="term-bar">
				<span class="term-logo"><Logo /></span>
				<p class="term-title"><span class="user">visitor@cli.masoko.net</span>:~$ {command}</p>
				{backHref && <a class="back" href={backHref}>&larr; cd ..</a>}
			</div>
			<div class="term-body">
				<slot />
			</div>
			<footer class="statusline">
				<span class="mode">{mode}</span>
				<span class="seg path">
					~/{breadcrumb.length > 0 ? <a href="/">cli.masoko.net</a> : 'cli.masoko.net'}
					{breadcrumb.map((segment, i) => (
						<>
							<span class="sep">/</span>
							{i < breadcrumb.length - 1 && segment.href ? (
								<a href={segment.href}>{segment.label}</a>
							) : (
								segment.label
							)}
						</>
					))}
				</span>
				{status && <span class="seg">{status}</span>}
				<span class="seg right">
					{editHref && (
						<>
							<a href={editHref}>edit</a>
							<span class="sep">·</span>
						</>
					)}
					<a href="/submit">submit</a>
					<span class="sep">·</span>
					<a href="https://github.com/hjelev/cli" target="_blank" rel="noopener">github</a>
				</span>
			</footer>
		</div>
	</body>
</html>
