---
import '../styles/global.css';

interface Props {
	title: string;
	command: string;
	mode?: string;
	status?: string;
	editHref?: string;
	backHref?: string;
	noindex?: boolean;
}

const { title, command, mode = 'NORMAL', status, editHref, backHref, noindex = false } = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" sizes="48x48" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		{noindex && <meta name="robots" content="noindex, follow" />}
		<title>{title}</title>
		<script defer src="https://m.masoko.net/core-util" data-website-id="b005feb8-941a-4967-b499-0a0b5f2eff9e"></script>
	</head>
	<body>
		<div class="term">
			<div class="term-bar">
				<div class="term-dots"><span></span><span></span><span></span></div>
				<svg class="term-logo" viewBox="0 0 128 128" aria-hidden="true">
					<rect width="128" height="128" rx="20" fill="var(--bg-deep)" />
					<rect x="26" y="19" width="11" height="11" rx="3" fill="var(--accent-green)" />
					<rect x="43" y="19" width="40" height="11" rx="3" fill="var(--fg)" />
					<rect x="26" y="43" width="60" height="11" rx="3" fill="var(--fg-dim)" />
					<rect x="26" y="67" width="38" height="11" rx="3" fill="var(--fg-dim)" />
					<rect x="26" y="91" width="16" height="18" rx="3" fill="var(--accent-rust)" />
				</svg>
				<p class="term-title"><span class="user">visitor@cli-tools</span>:~$ {command}</p>
				{backHref && <a class="back" href={backHref}>&larr; cd ..</a>}
			</div>
			<div class="term-body">
				<slot />
			</div>
			<footer class="statusline">
				<span class="mode">{mode}</span>
				<span class="seg path">~/cli-tools</span>
				{status && <span class="seg">{status}</span>}
				<span class="seg right">
					{editHref && (
						<>
							<a href={editHref}>edit</a>
							<span class="sep">·</span>
						</>
					)}
					<a href="/submit">submit</a>
					<span class="sep">·</span>
					<a href="https://github.com/hjelev/cli" target="_blank" rel="noopener">github</a>
				</span>
			</footer>
		</div>
	</body>
</html>
