---
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	// Distinct language names can share a slug, so group by slug: one page
	// per slug, listing every tool whose language maps to it.
	const languagesBySlug = new Map<string, string[]>();
	for (const tool of tools) {
		const slug = slugify(tool.data.language);
		const languages = languagesBySlug.get(slug) ?? [];
		if (!languages.includes(tool.data.language)) languages.push(tool.data.language);
		languagesBySlug.set(slug, languages);
	}
	return [...languagesBySlug.entries()].map(([slug, languages]) => ({
		params: { language: slug },
		props: {
			language: languages.join(' / '),
			tools: tools.filter((tool) => slugify(tool.data.language) === slug),
		},
	}));
}

const { language, tools } = Astro.props;
---

<BaseLayout title={`${language} — CLI Tools Directory`} command={`ls languages/${slugify(language)}`}>
	<a class="back" href="/languages">&larr; cd ..</a>

	<header class="hero">
		<h1>{language}</h1>
		<p class="tagline"># {tools.length} tool{tools.length === 1 ? '' : 's'} written in {language}</p>
	</header>

	<ul id="tool-grid">{tools.map((tool) => <ToolCard tool={tool} />)}</ul>
</BaseLayout>
