---
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = await getCollection('tools');
// Group by slug so languages that collide (see languages/[language]/[...page].astro)
// get one entry whose count matches the page it links to.
const bySlug = new Map<string, { label: string; toolIds: Set<string> }>();
for (const tool of tools) {
	const slug = slugify(tool.data.language);
	const entry = bySlug.get(slug) ?? { label: tool.data.language, toolIds: new Set<string>() };
	if (!entry.label.split(' / ').includes(tool.data.language)) entry.label += ` / ${tool.data.language}`;
	entry.toolIds.add(tool.id);
	bySlug.set(slug, entry);
}
const languages = [...bySlug.entries()]
	.map(([slug, { label, toolIds }]) => ({ slug, label, count: toolIds.size }))
	.sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="Languages — The Terminal Index" command="ls languages/" backHref="/">
	<header class="hero">
		<h1>Languages</h1>
		<p class="tagline"># browse tools by language</p>
		<nav class="browse-links">
			<a href="/categories">ls categories/</a>
			<a href="/tags">ls tags/</a>
		</nav>
	</header>

	<ul class="links">
		{
			languages.map(({ slug, label, count }) => (
				<li>
					<a href={`/languages/${slug}`}>
						{label} <span class="count">({count})</span>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>
