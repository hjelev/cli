---
import type { GetStaticPaths } from 'astro';
import { getCollection } from 'astro:content';
import { sortByUpdated } from '../../../lib/tools';
import { slugify } from '../../../lib/slug';
import { PAGE_SIZE, MIN_INDEXABLE_LISTINGS } from '../../../lib/config';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import ToolCard from '../../../components/ToolCard.astro';
import Pagination from '../../../components/Pagination.astro';
import Logo from '../../../components/Logo.astro';

export const getStaticPaths = (async ({ paginate }) => {
	const tools = await getCollection('tools');
	// Distinct language names can share a slug, so group by slug: one page (set)
	// per slug, listing every tool whose language maps to it.
	const languagesBySlug = new Map<string, string[]>();
	for (const tool of tools) {
		const slug = slugify(tool.data.language);
		const languages = languagesBySlug.get(slug) ?? [];
		if (!languages.includes(tool.data.language)) languages.push(tool.data.language);
		languagesBySlug.set(slug, languages);
	}
	return [...languagesBySlug.entries()].flatMap(([slug, languages]) =>
		paginate(
			sortByUpdated(tools.filter((tool) => slugify(tool.data.language) === slug)),
			{
				params: { language: slug },
				props: { language: languages.join(' / ') },
				pageSize: PAGE_SIZE,
			},
		),
	);
}) satisfies GetStaticPaths;

const { page, language } = Astro.props;
---

<BaseLayout
	title={`${language} — The Terminal Index`}
	command={`ls languages/${slugify(language)}`}
	backHref="/languages"
	noindex={page.total < MIN_INDEXABLE_LISTINGS}
>
	<header class="hero">
		<h1><Logo />{language}</h1>
		<p class="tagline"># {page.total} tool{page.total === 1 ? '' : 's'} written in {language}</p>
	</header>

	<ul id="tool-grid">{page.data.map((tool) => <ToolCard tool={tool} />)}</ul>

	<Pagination page={page} />
</BaseLayout>
