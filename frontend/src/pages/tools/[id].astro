---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map((tool) => ({ params: { id: tool.id }, props: { tool } }));
}

const { tool } = Astro.props;
const { data } = tool;
const { Content } = await render(tool);
---

<BaseLayout title={`${data.name} — CLI Tools Directory`} command={`man ${tool.id}`}>
	<a class="back" href="/">&larr; cd ..</a>

	<header class="man-header">
		{data.logo && <img src={data.logo} alt="" width="48" height="48" />}
		<div>
			<h1>{data.name}<span class="num">(1)</span></h1>
			<p class="tagline">{data.short_description}</p>
		</div>
	</header>

	<section class="man-section">
		<h2>NAME</h2>
		<p>{data.name} — {data.short_description}</p>
	</section>

	<section class="man-section">
		<h2>DESCRIPTION</h2>
		<p>{data.description}</p>
		<div class="content">
			<Content />
		</div>
	</section>

	<section class="man-section">
		<h2>INSTALLATION</h2>
		<div class="install-list">
			{data.installation.map((entry) => (
				<div class="install-entry">
					<span class="badge">{entry.method}</span>
					<pre class="code"><code>$ {entry.command}</code></pre>
				</div>
			))}
		</div>
	</section>

	<section class="man-section">
		<h2>DETAILS</h2>
		<dl>
			<dt>Author</dt>
			<dd>{data.author}</dd>

			<dt>License</dt>
			<dd>{data.license}</dd>

			<dt>Category</dt>
			<dd>{data.category}</dd>

			<dt>Language</dt>
			<dd>{data.language}</dd>

			<dt>Platforms</dt>
			<dd>{data.platforms.join(', ')}</dd>
		</dl>
	</section>

	<section class="man-section">
		<h2>SEE ALSO</h2>
		<ul class="links">
			<li>
				<a href={data.repository_url} target="_blank" rel="noopener">Repository &nearr;</a>
			</li>
			{
				data.website && (
					<li>
						<a href={data.website} target="_blank" rel="noopener">
							Website &nearr;
						</a>
					</li>
				)
			}
		</ul>
	</section>

	<section class="man-section">
		<h2>TAGS</h2>
		<ul class="tags">
			{data.tags.map((tag) => (
				<li>{tag}</li>
			))}
		</ul>
	</section>

	{data.media && <img class="media" src={data.media} alt={`${data.name} demo`} />}
</BaseLayout>
