---
import { getCollection, render } from 'astro:content';
import { marked } from 'marked';
import { slugify } from '../../lib/slug';
import { getRelatedTools } from '../../lib/tools';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map((tool) => ({
		params: { id: tool.id },
		props: { tool, relatedTools: getRelatedTools(tool, tools) },
	}));
}

const { tool, relatedTools } = Astro.props;
const { data } = tool;
const { Content } = await render(tool);

const descriptionHtml = marked.parse(data.description, { async: false });

const comments = [...(data.comments ?? [])].sort((a, b) => b.date.localeCompare(a.date));
const fmtDate = (iso: string) => (iso ? iso.slice(0, 10) : '');

const githubStars = data.github_stars;
const githubStarsLabel =
	githubStars !== undefined
		? new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(githubStars)
		: null;

let faviconUrl = '';
if (data.website) {
	try {
		const host = 'https://' + new URL(data.website).hostname;
		faviconUrl = `https://www.google.com/s2/favicons?domain=${host}&sz=32`;
	} catch {
		faviconUrl = ''; // malformed URL → no icon
	}
}
---

<BaseLayout
	title={`${data.name} — The Terminal Index`}
	command={`man ${tool.id}`}
	editHref={`/tools/${tool.id}/edit`}
	backHref="/"
	breadcrumb={[
		{ label: slugify(data.category), href: `/categories/${slugify(data.category)}` },
		{ label: tool.id },
	]}
>
	<header class="man-header">
		<div class="logo-stack">
			{data.logo && <img src={data.logo} alt="" width="48" height="48" />}
			{githubStarsLabel && (
				<span class="badge badge-stars" title={`${githubStars} GitHub stars`}>★ {githubStarsLabel}</span>
			)}
		</div>
		<div>
			<h1>{data.name}<span class="num"></span></h1>
			<p class="tagline">{data.short_description}</p>
		</div>
	</header>

	{data.media && (/\.(webm|mp4)(\?.*)?$/i.test(data.media)
		? <video class="media" src={data.media} autoplay loop muted playsinline controls />
		: <img class="media" src={data.media} alt={`${data.name} demo`} />
	)}

	<section class="man-section">
		<h2>DESCRIPTION</h2>
		<div class="description" set:html={descriptionHtml} />
		<div class="content">
			<Content />
		</div>
	</section>

	<section class="man-section">
		<h2>INSTALLATION</h2>
		<div class="install-tabs">
			{
				data.installation.length > 1 && (
					<div class="tab-list" role="tablist">
						{data.installation.map((entry, i) => (
							<button
								type="button"
								role="tab"
								id={`tab-${i}`}
								aria-controls={`panel-${i}`}
								aria-selected={i === 0}
								class={`tab-btn${i === 0 ? ' active' : ''}`}
							>
								{entry.method}
							</button>
						))}
					</div>
				)
			}
			{
				data.installation.map((entry, i) => (
					<div
						class="tab-panel"
						role="tabpanel"
						id={`panel-${i}`}
						aria-labelledby={`tab-${i}`}
						hidden={i !== 0}
					>
						<pre class="code"><code>$ {entry.command}</code></pre>
						<button
							type="button"
							class="copy-btn"
							data-command={entry.command}
							aria-label="Copy command to clipboard"
						>
							<svg class="icon-copy" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
								<path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z" />
								<path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z" />
							</svg>
							<svg
								class="icon-check"
								viewBox="0 0 16 16"
								width="16"
								height="16"
								fill="currentColor"
								style="display: none"
							>
								<path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
							</svg>
						</button>
					</div>
				))
			}
		</div>
	</section>

	<section class="man-section">
		<h2>DETAILS</h2>
		<dl>
			<dt>Repository</dt>
			<dd>
				<svg class="favicon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
					<path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8Z" />
				</svg>
				<a href={data.repository_url} target="_blank" rel="noopener">{data.repository_url.replace(/^https?:\/\/(www\.)?github\.com\//, '')}</a>
			</dd>

			{data.website && (
				<>
					<dt>Website</dt>
					<dd>
						{faviconUrl && (
							<img
								class="favicon"
								src={faviconUrl}
								alt=""
								width="16"
								height="16"
								loading="lazy"
							/>
						)}
						<a href={data.website} target="_blank" rel="noopener">{data.website.replace(/^https?:\/\//, '')}</a>
					</dd>
				</>
			)}

			<dt>Author</dt>
			<dd>{data.author}</dd>

			<dt>License</dt>
			<dd>{data.license}</dd>

			<dt>Category</dt>
			<dd><a href={`/categories/${slugify(data.category)}`}>{data.category}</a></dd>

			<dt>Language</dt>
			<dd><a href={`/languages/${slugify(data.language)}`}>{data.language}</a></dd>

			<dt>Platforms</dt>
			<dd>{data.platforms.join(', ')}</dd>

{data.github_updated && (
				<>
					<dt>Last Updated</dt>
					<dd>{fmtDate(data.github_updated)}</dd>
				</>
			)}

			{data.github_release && (
				<>
					<dt>Latest Release</dt>
					<dd>{data.github_release}</dd>
				</>
			)}
		</dl>
	</section>

	<section class="man-section">
		<h2>TAGS</h2>
		<ul class="tags">
			{data.tags.map((tag) => (
				<li>
					<a href={`/tags/${slugify(tag)}`}>{tag}</a>
				</li>
			))}
		</ul>
	</section>

	<section class="man-section feedback" id="feedback" data-tool-id={tool.id}>
		<h2>COMMENTS</h2>
		<ul class="comment-list" id="comment-list">
			{comments.map((c) => (
				<li class="comment">
					<div class="comment-head">
						<span class="comment-user">@{c.user}</span>
						<span class="comment-date">{fmtDate(c.date)}</span>
					</div>
					<p class="comment-body">{c.body}</p>
				</li>
			))}
			{comments.length === 0 && <li class="comment-empty">No comments yet. Be the first.</li>}
		</ul>

		<form class="comment-form" id="comment-form" hidden>
			<textarea id="comment-input" rows="3" maxlength="2000" placeholder="Leave a comment…" required></textarea>
			<button type="submit">Post comment</button>
		</form>

		<p class="feedback-signin" hidden>
			<button type="button" class="link-btn feedback-signin-btn">Sign in with GitHub</button> to comment.
		</p>

		<p id="feedback-status" role="status"></p>
	</section>

	{relatedTools.length > 0 && (
		<section class="man-section man-section-no-hash">
			<h2>MORE IN {data.category.toUpperCase()}</h2>
			<ul id="tool-grid">{relatedTools.map((t) => <ToolCard tool={t} />)}</ul>
		</section>
	)}
</BaseLayout>

<script>
	document.querySelectorAll<HTMLElement>('.install-tabs').forEach((container) => {
		const tabs = container.querySelectorAll<HTMLButtonElement>('[role="tab"]');
		const panels = container.querySelectorAll<HTMLElement>('.tab-panel');

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => {
					t.setAttribute('aria-selected', 'false');
					t.classList.remove('active');
				});
				panels.forEach((panel) => {
					panel.hidden = true;
				});

				tab.setAttribute('aria-selected', 'true');
				tab.classList.add('active');
				const panel = container.querySelector<HTMLElement>(`#${tab.getAttribute('aria-controls')}`);
				if (panel) panel.hidden = false;
			});
		});

		container.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
			let revertTimer: ReturnType<typeof setTimeout>;

			btn.addEventListener('click', async () => {
				const command = btn.dataset.command;
				if (!command) return;

				await navigator.clipboard.writeText(command);

				const copyIcon = btn.querySelector<HTMLElement>('.icon-copy');
				const checkIcon = btn.querySelector<HTMLElement>('.icon-check');
				if (copyIcon) copyIcon.style.display = 'none';
				if (checkIcon) checkIcon.style.display = '';
				btn.classList.add('copied');

				clearTimeout(revertTimer);
				revertTimer = setTimeout(() => {
					if (copyIcon) copyIcon.style.display = '';
					if (checkIcon) checkIcon.style.display = 'none';
					btn.classList.remove('copied');
				}, 1500);
			});
		});
	});
</script>

<script>
	import { getStoredToken, redirectToGitHubSignIn } from '../../lib/github-auth';
	import { submitFeedback } from '../../lib/feedback';

	const root = document.getElementById('feedback');
	const toolId = root?.dataset.toolId;
	const status = document.getElementById('feedback-status') as HTMLElement | null;
	const commentForm = document.getElementById('comment-form') as HTMLFormElement | null;
	const commentInput = document.getElementById('comment-input') as HTMLTextAreaElement | null;
	const commentList = document.getElementById('comment-list');
	const signinPrompts = Array.from(document.querySelectorAll<HTMLElement>('.feedback-signin'));

	const REBUILD_NOTE = 'Saved! It will appear here after the site rebuilds.';

	function setStatus(message: string, isError = false) {
		if (!status) return;
		status.textContent = message;
		status.classList.toggle('error', isError);
	}

	function renderSignedIn(signedIn: boolean) {
		if (commentForm) commentForm.hidden = !signedIn;
		signinPrompts.forEach((el) => (el.hidden = signedIn));
	}

	function initFeedback() {
		if (!toolId) return;
		renderSignedIn(Boolean(getStoredToken()));

		signinPrompts
			.flatMap((el) => Array.from(el.querySelectorAll<HTMLButtonElement>('.feedback-signin-btn')))
			.forEach((btn) => btn.addEventListener('click', () => redirectToGitHubSignIn(window.location.pathname)));

		commentForm?.addEventListener('submit', submitComment);
	}

	async function submitComment(event: SubmitEvent) {
		event.preventDefault();
		const token = getStoredToken();
		if (!token || !toolId || !commentInput) return;
		const body = commentInput.value.trim();
		if (!body) return;

		const submitBtn = commentForm?.querySelector('button[type="submit"]') as HTMLButtonElement | null;
		if (submitBtn) submitBtn.disabled = true;
		setStatus('Posting your comment…');
		try {
			const result = await submitFeedback(token, { toolId, comment: body });
			appendComment(result.user.login, body, result.date);
			commentInput.value = '';
			setStatus(REBUILD_NOTE);
		} catch (err) {
			setStatus(err instanceof Error ? err.message : 'Could not post your comment.', true);
		} finally {
			if (submitBtn) submitBtn.disabled = false;
		}
	}

	// Optimistically show the just-posted comment; the committed copy lands on
	// the next rebuild.
	function appendComment(user: string, body: string, date: string) {
		if (!commentList) return;
		commentList.querySelector('.comment-empty')?.remove();
		const li = document.createElement('li');
		li.className = 'comment pending';
		const head = document.createElement('div');
		head.className = 'comment-head';
		const userEl = document.createElement('span');
		userEl.className = 'comment-user';
		userEl.textContent = `@${user}`;
		const dateEl = document.createElement('span');
		dateEl.className = 'comment-date';
		dateEl.textContent = date.slice(0, 10);
		head.append(userEl, dateEl);
		const bodyEl = document.createElement('p');
		bodyEl.className = 'comment-body';
		bodyEl.textContent = body; // textContent — never innerHTML — avoids XSS.
		li.append(head, bodyEl);
		commentList.prepend(li);
	}

	initFeedback();
</script>
