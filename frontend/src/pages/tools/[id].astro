---
import { getCollection, render } from 'astro:content';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return tools.map((tool) => ({ params: { id: tool.id }, props: { tool } }));
}

const { tool } = Astro.props;
const { data } = tool;
const { Content } = await render(tool);
---

<BaseLayout title={`${data.name} — CLI Tools Directory`} command={`man ${tool.id}`}>
	<a class="back" href="/">&larr; cd ..</a>

	<header class="man-header">
		{data.logo && <img src={data.logo} alt="" width="48" height="48" />}
		<div>
			<h1>{data.name}<span class="num"></span></h1>
			<p class="tagline">{data.short_description}</p>
		</div>
	</header>

	<section class="man-section">
		<h2>DESCRIPTION</h2>
		<p>{data.description}</p>
		<div class="content">
			<Content />
		</div>
	</section>

	<section class="man-section">
		<h2>INSTALLATION</h2>
		<div class="install-tabs">
			{
				data.installation.length > 1 && (
					<div class="tab-list" role="tablist">
						{data.installation.map((entry, i) => (
							<button
								type="button"
								role="tab"
								id={`tab-${i}`}
								aria-controls={`panel-${i}`}
								aria-selected={i === 0}
								class={`tab-btn${i === 0 ? ' active' : ''}`}
							>
								{entry.method}
							</button>
						))}
					</div>
				)
			}
			{
				data.installation.map((entry, i) => (
					<div
						class="tab-panel"
						role="tabpanel"
						id={`panel-${i}`}
						aria-labelledby={`tab-${i}`}
						hidden={i !== 0}
					>
						<pre class="code"><code>$ {entry.command}</code></pre>
						<button
							type="button"
							class="copy-btn"
							data-command={entry.command}
							aria-label="Copy command to clipboard"
						>
							<svg class="icon-copy" viewBox="0 0 16 16" width="16" height="16" fill="currentColor">
								<path d="M0 6.75C0 5.784.784 5 1.75 5h1.5a.75.75 0 0 1 0 1.5h-1.5a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-1.5a.75.75 0 0 1 1.5 0v1.5A1.75 1.75 0 0 1 9.25 16h-7.5A1.75 1.75 0 0 1 0 14.25Z" />
								<path d="M5 1.75C5 .784 5.784 0 6.75 0h7.5C15.216 0 16 .784 16 1.75v7.5A1.75 1.75 0 0 1 14.25 11h-7.5A1.75 1.75 0 0 1 5 9.25Zm1.75-.25a.25.25 0 0 0-.25.25v7.5c0 .138.112.25.25.25h7.5a.25.25 0 0 0 .25-.25v-7.5a.25.25 0 0 0-.25-.25Z" />
							</svg>
							<svg
								class="icon-check"
								viewBox="0 0 16 16"
								width="16"
								height="16"
								fill="currentColor"
								style="display: none"
							>
								<path d="M13.78 4.22a.75.75 0 0 1 0 1.06l-7.25 7.25a.75.75 0 0 1-1.06 0L2.22 9.28a.75.75 0 0 1 1.06-1.06L6 10.94l6.72-6.72a.75.75 0 0 1 1.06 0Z" />
							</svg>
						</button>
					</div>
				))
			}
		</div>
	</section>

	<section class="man-section">
		<h2>DETAILS</h2>
		<dl>
			<dt>Author</dt>
			<dd>{data.author}</dd>

			<dt>License</dt>
			<dd>{data.license}</dd>

			<dt>Category</dt>
			<dd><a href={`/categories/${slugify(data.category)}`}>{data.category}</a></dd>

			<dt>Language</dt>
			<dd>{data.language}</dd>

			<dt>Platforms</dt>
			<dd>{data.platforms.join(', ')}</dd>
		</dl>
	</section>

	<section class="man-section">
		<h2>SEE ALSO</h2>
		<ul class="links">
			<li>
				<a href={data.repository_url} target="_blank" rel="noopener">Repository &nearr;</a>
			</li>
			{
				data.website && (
					<li>
						<a href={data.website} target="_blank" rel="noopener">
							Website &nearr;
						</a>
					</li>
				)
			}
		</ul>
	</section>

	<section class="man-section">
		<h2>TAGS</h2>
		<ul class="tags">
			{data.tags.map((tag) => (
				<li>
					<a href={`/tags/${slugify(tag)}`}>{tag}</a>
				</li>
			))}
		</ul>
	</section>

	{data.media && <img class="media" src={data.media} alt={`${data.name} demo`} />}
</BaseLayout>

<script>
	document.querySelectorAll<HTMLElement>('.install-tabs').forEach((container) => {
		const tabs = container.querySelectorAll<HTMLButtonElement>('[role="tab"]');
		const panels = container.querySelectorAll<HTMLElement>('.tab-panel');

		tabs.forEach((tab) => {
			tab.addEventListener('click', () => {
				tabs.forEach((t) => {
					t.setAttribute('aria-selected', 'false');
					t.classList.remove('active');
				});
				panels.forEach((panel) => {
					panel.hidden = true;
				});

				tab.setAttribute('aria-selected', 'true');
				tab.classList.add('active');
				const panel = container.querySelector<HTMLElement>(`#${tab.getAttribute('aria-controls')}`);
				if (panel) panel.hidden = false;
			});
		});

		container.querySelectorAll<HTMLButtonElement>('.copy-btn').forEach((btn) => {
			let revertTimer: ReturnType<typeof setTimeout>;

			btn.addEventListener('click', async () => {
				const command = btn.dataset.command;
				if (!command) return;

				await navigator.clipboard.writeText(command);

				const copyIcon = btn.querySelector<HTMLElement>('.icon-copy');
				const checkIcon = btn.querySelector<HTMLElement>('.icon-check');
				if (copyIcon) copyIcon.style.display = 'none';
				if (checkIcon) checkIcon.style.display = '';
				btn.classList.add('copied');

				clearTimeout(revertTimer);
				revertTimer = setTimeout(() => {
					if (copyIcon) copyIcon.style.display = '';
					if (checkIcon) checkIcon.style.display = 'none';
					btn.classList.remove('copied');
				}, 1500);
			});
		});
	});
</script>
