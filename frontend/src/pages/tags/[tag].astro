---
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	// Distinct tags can share a slug (e.g. "C++" and "C#" → "c"), so group by
	// slug: one page per slug, listing every tool whose tags map to it.
	const tagsBySlug = new Map<string, string[]>();
	for (const tool of tools) {
		for (const tag of tool.data.tags) {
			const slug = slugify(tag);
			const tags = tagsBySlug.get(slug) ?? [];
			if (!tags.includes(tag)) tags.push(tag);
			tagsBySlug.set(slug, tags);
		}
	}
	return [...tagsBySlug.entries()].map(([slug, tags]) => ({
		params: { tag: slug },
		props: {
			tag: tags.join(' / '),
			tools: tools.filter((tool) => tool.data.tags.some((t) => slugify(t) === slug)),
		},
	}));
}

const { tag, tools } = Astro.props;
---

<BaseLayout title={`#${tag} — CLI Tools Directory`} command={`ls tags/${slugify(tag)}`}>
	<a class="back" href="/tags">&larr; cd ..</a>

	<header class="hero">
		<h1>#{tag}</h1>
		<p class="tagline"># {tools.length} tool{tools.length === 1 ? '' : 's'} tagged {tag}</p>
	</header>

	<ul id="tool-grid">{tools.map((tool) => <ToolCard tool={tool} />)}</ul>
</BaseLayout>
