---
import { getCollection } from 'astro:content';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';

const tools = await getCollection('tools');
// Group by slug so tags that collide (see tags/[tag]/[...page].astro) get one entry
// whose count matches the page it links to.
const bySlug = new Map<string, { label: string; toolIds: Set<string> }>();
for (const tool of tools) {
	for (const tag of tool.data.tags) {
		const slug = slugify(tag);
		const entry = bySlug.get(slug) ?? { label: tag, toolIds: new Set<string>() };
		if (!entry.label.split(' / ').includes(tag)) entry.label += ` / ${tag}`;
		entry.toolIds.add(tool.id);
		bySlug.set(slug, entry);
	}
}
const tags = [...bySlug.entries()]
	.map(([slug, { label, toolIds }]) => ({ slug, label, count: toolIds.size }))
	.sort((a, b) => a.slug.localeCompare(b.slug));
---

<BaseLayout title="Tags — The Terminal Index" command="ls tags/">
	<a class="back" href="/">&larr; cd ..</a>

	<header class="hero">
		<h1>Tags</h1>
		<p class="tagline"># browse tools by tag</p>
		<nav class="browse-links">
			<a href="/categories">ls categories/</a>
			<a href="/languages">ls languages/</a>
		</nav>
	</header>

	<ul class="links">
		{
			tags.map(({ slug, label, count }) => (
				<li>
					<a href={`/tags/${slug}`}>
						#{label} <span class="count">({count})</span>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>
