---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Signing in… — The Terminal Index" command="auth --callback">
	<p id="status" class="status-line">Signing you in…</p>

	<script>
		import { handleOAuthCallback } from '../../lib/github-auth';

		const statusEl = document.getElementById('status')!;

		handleOAuthCallback().then((result) => {
			if (result.ok) {
				window.location.replace(result.returnTo);
			} else {
				statusEl.textContent = `Sign-in failed: ${result.error}`;
			}
		});
	</script>
</BaseLayout>
