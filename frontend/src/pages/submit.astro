---
import ToolForm from '../components/ToolForm.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Submit a tool — The Terminal Index" command="submit --new">
	<a class="back" href="/">&larr; cd ..</a>
	<h1>Submit a tool</h1>
	<p class="form-note">Sign in with GitHub to submit a tool. Submitting opens a pull request from your own fork.</p>

	<section id="signed-out">
		<button id="sign-in-btn" type="button">Sign in with GitHub</button>
	</section>

	<section id="signed-in" hidden>
		<p id="signed-in-as"></p>
		<button id="sign-out-btn" type="button">Sign out</button>

		<ToolForm submitLabel="Submit for review" />

		<p id="form-status" role="status"></p>
	</section>

	<script>
		import { getStoredToken, redirectToGitHubSignIn, signOut, fetchGitHubUser } from '../lib/github-auth';
		import { submitTool } from '../lib/github-submit';
		import { toolFormSchema } from '../lib/schema';
		import {
			extractUploadFiles,
			initInstallationRows,
			initUploadToggles,
			readCandidate,
			resetInstallationRows,
		} from '../lib/tool-form-client';
		import { validateUploadFile } from '../lib/upload';

		const signedOutSection = document.getElementById('signed-out') as HTMLElement;
		const signedInSection = document.getElementById('signed-in') as HTMLElement;
		const signedInAs = document.getElementById('signed-in-as') as HTMLElement;
		const form = document.getElementById('tool-form') as HTMLFormElement;
		const formStatus = document.getElementById('form-status') as HTMLElement;
		const installationRows = document.getElementById('installation-rows') as HTMLElement;
		const addInstallationRowBtn = document.getElementById('add-installation-row') as HTMLButtonElement;
		const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

		initInstallationRows(installationRows, addInstallationRowBtn);
		initUploadToggles(form);

		document.getElementById('sign-in-btn')?.addEventListener('click', () => {
			redirectToGitHubSignIn('/submit');
		});

		document.getElementById('sign-out-btn')?.addEventListener('click', () => {
			signOut();
			window.location.reload();
		});

		async function init() {
			const token = getStoredToken();
			if (!token) {
				signedOutSection.hidden = false;
				signedInSection.hidden = true;
				return;
			}

			try {
				const user = await fetchGitHubUser(token);
				signedInAs.textContent = `Signed in as @${user.login}`;
				signedOutSection.hidden = true;
				signedInSection.hidden = false;
			} catch {
				signOut();
				signedOutSection.hidden = false;
				signedInSection.hidden = true;
			}
		}

		form?.addEventListener('submit', async (event) => {
			event.preventDefault();
			const token = getStoredToken();
			if (!token) return;

			const candidate = readCandidate(form);
			const validation = toolFormSchema.safeParse(candidate);
			if (!validation.success) {
				formStatus.textContent = `Please fix: ${validation.error.issues.map((issue) => issue.message).join(', ')}`;
				return;
			}

			const files = extractUploadFiles(form);
			for (const file of Object.values(files)) {
				const error = file && validateUploadFile(file);
				if (error) {
					formStatus.textContent = `Please fix: ${error}`;
					return;
				}
			}

			formStatus.textContent = 'Submitting — forking, committing, and opening a pull request…';
			submitBtn.disabled = true;

			try {
				const { prUrl } = await submitTool(token, validation.data, files);
				const link = document.createElement('a');
				link.href = prUrl;
				link.target = '_blank';
				link.rel = 'noopener';
				link.textContent = 'View your pull request';
				formStatus.replaceChildren('Submitted! ', link, '.');
				form.reset();
				resetInstallationRows(installationRows);
			} catch (error) {
				formStatus.textContent = error instanceof Error ? error.message : 'Submission failed.';
			} finally {
				submitBtn.disabled = false;
			}
		});

		init();
	</script>
</BaseLayout>
