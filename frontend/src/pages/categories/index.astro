---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../lib/schema';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Logo from '../../components/Logo.astro';

const tools = await getCollection('tools');
const counts = new Map<string, number>();
for (const tool of tools) {
	counts.set(tool.data.category, (counts.get(tool.data.category) ?? 0) + 1);
}
const nonEmptyCategories = CATEGORIES.filter((category) => (counts.get(category) ?? 0) > 0);
---

<BaseLayout title="Categories — The Terminal Index" command="ls categories/" backHref="/">
	<header class="hero">
		<h1><Logo />Categories</h1>
		<p class="tagline"># browse tools grouped by category</p>
		<nav class="browse-links">
			<a href="/tags">ls tags/</a>
			<a href="/languages">ls languages/</a>
		</nav>
	</header>

	<ul class="links">
		{
			nonEmptyCategories.map((category) => (
				<li>
					<a href={`/categories/${slugify(category)}`}>
						{category} <span class="count">({counts.get(category)})</span>
					</a>
				</li>
			))
		}
	</ul>
</BaseLayout>
