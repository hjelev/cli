---
import { getCollection } from 'astro:content';
import { CATEGORIES } from '../../lib/schema';
import { slugify } from '../../lib/slug';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ToolCard from '../../components/ToolCard.astro';

export async function getStaticPaths() {
	const tools = await getCollection('tools');
	return CATEGORIES.map((category) => ({
		params: { category: slugify(category) },
		props: { category, tools: tools.filter((tool) => tool.data.category === category) },
	}));
}

const { category, tools } = Astro.props;
---

<BaseLayout title={`${category} — CLI Tools Directory`} command={`ls categories/${slugify(category)}`}>
	<a class="back" href="/categories">&larr; cd ..</a>

	<header class="hero">
		<h1>{category}</h1>
		<p class="tagline"># {tools.length} tool{tools.length === 1 ? '' : 's'} in this category</p>
	</header>

	{
		tools.length > 0 ? (
			<ul id="tool-grid">{tools.map((tool) => <ToolCard tool={tool} />)}</ul>
		) : (
			<p>No tools in this category yet.</p>
		)
	}
</BaseLayout>
