---
import type { Page } from 'astro';

interface Props {
	page: Page;
}

const { page } = Astro.props;
const { currentPage, lastPage } = page;

// Base path shared by every page in this set (i.e. page 1's path). `page.url.first`
// is undefined while on page 1, so derive the base from the current URL instead by
// stripping any trailing `/<currentPage>` segment. Works for the root ('/') and for
// nested routes ('/categories/cli').
const stripped = page.url.current.replace(new RegExp(`/${currentPage}/?$`), '');
const base = stripped === '/' ? '' : stripped.replace(/\/$/, '');
const href = (n: number) => (n === 1 ? base || '/' : `${base}/${n}`);

type PageEntry = number | '...';

// Windows the visible page numbers to at most `delta * 2 + 1` around the current
// page, always pinning page 1 and the last page. A single hidden page is merged
// into the visible range rather than replaced by '...', since an ellipsis for
// just one skipped page reads as noise rather than a useful compaction.
function getPageNumbers(current: number, last: number, delta = 2): PageEntry[] {
	let start = current - delta;
	let end = current + delta;

	if (start < 1) {
		end += 1 - start;
		start = 1;
	}
	if (end > last) {
		start -= end - last;
		end = last;
	}
	start = Math.max(1, start);
	end = Math.min(last, end);

	if (start === 3) start = 2;
	if (end === last - 2) end = last - 1;

	const pages: PageEntry[] = [];

	if (start > 1) {
		pages.push(1);
		if (start > 2) pages.push('...');
	}

	for (let i = start; i <= end; i++) pages.push(i);

	if (end < last) {
		if (end < last - 1) pages.push('...');
		pages.push(last);
	}

	return pages;
}

const numbers = getPageNumbers(currentPage, lastPage);
---

{
	lastPage > 1 && (
		<nav class="pagination" aria-label="Pagination">
			{page.url.prev ? (
				<a class="page-nav" href={page.url.prev} rel="prev">&larr; prev</a>
			) : (
				<span class="page-nav disabled">&larr; prev</span>
			)}

			<ul class="page-numbers">
				{numbers.map((n) => (
					<li>
						{n === '...' ? (
							<span class="page-ellipsis">&hellip;</span>
						) : n === currentPage ? (
							<span class="page-num current" aria-current="page">{n}</span>
						) : (
							<a class="page-num" href={href(n)}>{n}</a>
						)}
					</li>
				))}
			</ul>

			{page.url.next ? (
				<a class="page-nav" href={page.url.next} rel="next">next &rarr;</a>
			) : (
				<span class="page-nav disabled">next &rarr;</span>
			)}
		</nav>
	)
}
