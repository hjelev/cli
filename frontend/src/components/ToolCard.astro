---
import type { CollectionEntry } from 'astro:content';

interface Props {
	tool: CollectionEntry<'tools'>;
}

const { tool } = Astro.props;

const githubStars = tool.data.github_stars;
const githubStarsLabel =
	githubStars !== undefined
		? new Intl.NumberFormat('en-US', { notation: 'compact', maximumFractionDigits: 1 }).format(githubStars)
		: null;
---

<li
	class="tool-card"
	data-category={tool.data.category}
	data-language={tool.data.language}
	data-search={`${tool.data.name} ${tool.data.short_description} ${tool.data.tags.join(' ')}`.toLowerCase()}
>
	<a href={`/tools/${tool.id}`}>
		<div class="tool-name">
			{tool.data.logo && <img src={tool.data.logo} alt={`${tool.data.name} logo`} width="44" height="44" />}
			<div class="tool-name-text">
				<h2>{tool.data.name}</h2>
				<span class="badge">{tool.data.language}</span>
			</div>
		</div>
		<p>{tool.data.short_description}</p>
		<div class="badges">
			{githubStarsLabel && (
				<span class="badge badge-stars" title={`${githubStars} GitHub stars`}>★ {githubStarsLabel}</span>
			)}
			<span class="badge">{tool.data.category}</span>
		</div>
		<ul class="tags">
			{tool.data.tags.map((tag) => (
				<li>{tag}</li>
			))}
		</ul>
	</a>
</li>
