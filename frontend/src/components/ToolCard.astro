---
import type { CollectionEntry } from 'astro:content';
import { ratingSummary, stars } from '../lib/ratings';

interface Props {
	tool: CollectionEntry<'tools'>;
	index?: number;
}

const { tool, index } = Astro.props;
const marker = index != null ? String(index).padStart(2, '0') : '·';
const { count: ratingCount, average: ratingAverage } = ratingSummary(tool.data.ratings);
---

<li
	class="tool-card"
	data-category={tool.data.category}
	data-language={tool.data.language}
	data-search={`${tool.data.name} ${tool.data.short_description} ${tool.data.tags.join(' ')}`.toLowerCase()}
>
	<a href={`/tools/${tool.id}`}>
		<span class="tool-index" aria-hidden="true">{marker}</span>
		<div class="tool-name">
			{tool.data.logo && <img src={tool.data.logo} alt="" width="44" height="44" />}
			<h2>{tool.data.name}</h2>
		</div>
		<p>{tool.data.short_description}</p>
		{ratingCount > 0 && (
			<div class="card-rating" title={`${ratingAverage.toFixed(1)} out of 5 from ${ratingCount} rating${ratingCount === 1 ? '' : 's'}`}>
				<span class="stars">{stars(ratingAverage)}</span>
				<span class="rating-meta">{ratingAverage.toFixed(1)} ({ratingCount})</span>
			</div>
		)}
		<div class="badges">
			<span class="badge">{tool.data.language}</span>
			<span class="badge">{tool.data.category}</span>
		</div>
		<ul class="tags">
			{tool.data.tags.map((tag) => (
				<li>{tag}</li>
			))}
		</ul>
	</a>
</li>
