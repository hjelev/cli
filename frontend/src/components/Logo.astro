---
// The Terminal Index mark: an `ls` listing with the cursor on the next line.
// Same geometry as public/favicon.svg, but themed via CSS variables.
---

<svg class="title-logo" viewBox="0 0 128 128" aria-hidden="true">
	<rect width="128" height="128" rx="20" fill="var(--bg-deep)" />
	<rect x="2" y="2" width="124" height="124" rx="18" fill="none" stroke="var(--border)" stroke-width="4" />
	<rect x="26" y="19" width="11" height="11" rx="3" fill="var(--accent-green)" />
	<rect x="43" y="19" width="40" height="11" rx="3" fill="var(--fg)" />
	<rect x="26" y="43" width="60" height="11" rx="3" fill="var(--fg-dim)" />
	<rect x="26" y="67" width="38" height="11" rx="3" fill="var(--fg-dim)" />
	<rect x="26" y="91" width="16" height="18" rx="3" fill="var(--accent-rust)" />
</svg>
